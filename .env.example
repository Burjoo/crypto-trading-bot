# ─────────────────────────────────────────────────────────────
# CryptoBot Pro — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Security (CHANGE ALL OF THESE) ───────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-very-long-random-secret-key-min-32-characters

# Fernet key for AES encryption of API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=cryptobot
POSTGRES_PASSWORD=cryptobot_secret_change_me
POSTGRES_DB=cryptobot
DATABASE_URL=postgresql+asyncpg://cryptobot:cryptobot_secret_change_me@db:5432/cryptobot

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_me
REDIS_URL=redis://:redis_secret_change_me@redis:6379/0

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ─── Telegram Notifications (optional) ────────────────────────
# Create a bot via @BotFather on Telegram to get the token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Sentry Error Tracking (optional) ─────────────────────────
SENTRY_DSN=

# ─── Admin Account (created on first run) ─────────────────────
FIRST_SUPERUSER_EMAIL=admin@cryptobot.pro
FIRST_SUPERUSER_PASSWORD=changeme123!

# ─── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
